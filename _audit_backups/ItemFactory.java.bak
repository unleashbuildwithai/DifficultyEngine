    /** Builds 1 Support Rune — consumed each time the Support Staff is used. */
    public ItemStack buildSupportRune() {
        ItemStack item = new ItemStack(Material.PHANTOM_MEMBRANE);
        ItemMeta meta = item.getItemMeta();
        if (meta != null) {
            meta.setDisplayName("§5✦ Support Rune");
            meta.setEnchantmentGlintOverride(true);
            meta.setLore(List.of(
                "§7Consumed when activating the §dSupport Staff§7.",
                "§6Craft: §74× Phantom Membrane §8→ §58× Runes",
                "§8[DifficultyEngine — Support Rune]"
            ));
            meta.getPersistentDataContainer().set(supportRuneKey, PersistentDataType.BYTE, (byte) 1);
            item.setItemMeta(meta);
        }
        return item;
    }

    /** True if the item is a Support Rune. */
    public boolean isSupportRune(ItemStack item) {
        if (item == null || !item.hasItemMeta()) return false;
        return item.getItemMeta().getPersistentDataContainer()
                .has(supportRuneKey, PersistentDataType.BYTE);
    }

    /** Resolves a support page PDC key constant string to its NamespacedKey. */
    private NamespacedKey resolvePageKey(String keyConst) {
        return switch (keyConst) {
            case SUPPORT_PAGE_HEALING_KEY  -> supportPageHealingKey;
            case SUPPORT_PAGE_SPEED_KEY    -> supportPageSpeedKey;
            case SUPPORT_PAGE_DEFENCE_KEY  -> supportPageDefenceKey;
            case SUPPORT_PAGE_COMBAT_KEY   -> supportPageCombatKey;
            case SUPPORT_PAGE_STRENGTH_KEY -> supportPageStrengthKey;
            case SUPPORT_PAGE_CRIT_KEY     -> supportPageCritKey;
            case SUPPORT_PAGE_PRAYER_KEY   -> supportPagePrayerKey;
            case SUPPORT_PAGE_BULWARK_KEY       -> supportPageBulwarkKey;
            case SUPPORT_PAGE_CHRONO_KEY        -> supportPageChronoKey;
            case SUPPORT_PAGE_GRAVITIC_KEY      -> supportPageGraviticKey;
            case SUPPORT_PAGE_FEATHERWEIGHT_KEY -> supportPageFeatherweightKey;
            case SUPPORT_PAGE_OCULAR_KEY        -> supportPageOcularKey;
            case SUPPORT_PAGE_PYRIC_KEY         -> supportPagePyricKey;
            case SUPPORT_PAGE_ABYSSAL_KEY       -> supportPageAbyssalKey;
            case SUPPORT_PAGE_ENERVATION_KEY    -> supportPageEnervationKey;
            case SUPPORT_PAGE_STASIS_KEY        -> supportPageStasisKey;
            default                        -> null;
        };
    }

    /**
     * Maps a Support Blessing Potion's PDC id (the string passed to
     * {@link #buildSupportPotion}) to the PDC key constant of the page that
     * must be carried to arm that potion.  Returns {@code null} for potions
     * that intentionally share the original 7 pages (none currently do —
     * every potion added after the original 7 gets its own page).
     */
    public String resolveSupportPageKeyConstForPotion(String potionId) {
        return switch (potionId) {
            case "vitality_surge"      -> SUPPORT_PAGE_HEALING_KEY;
            case "zephyr_momentum"     -> SUPPORT_PAGE_SPEED_KEY;
            case "aegis_ward"          -> SUPPORT_PAGE_DEFENCE_KEY;
            case "berserker_resonance" -> SUPPORT_PAGE_COMBAT_KEY;
            case "aetheric_shielding"  -> SUPPORT_PAGE_STRENGTH_KEY;
            case "fortune_aura"        -> SUPPORT_PAGE_CRIT_KEY;
            case "veil_of_silence"     -> SUPPORT_PAGE_PRAYER_KEY;
            case "spell_breaker_bulwark"    -> SUPPORT_PAGE_BULWARK_KEY;
            case "chrono_mend"              -> SUPPORT_PAGE_CHRONO_KEY;
            case "gravitic_leap"            -> SUPPORT_PAGE_GRAVITIC_KEY;
            case "featherweight_descent"    -> SUPPORT_PAGE_FEATHERWEIGHT_KEY;
            case "ocular_sight"             -> SUPPORT_PAGE_OCULAR_KEY;
            case "pyric_mandate"            -> SUPPORT_PAGE_PYRIC_KEY;
            case "abyssal_lung"             -> SUPPORT_PAGE_ABYSSAL_KEY;
            case "enervation_curse"         -> SUPPORT_PAGE_ENERVATION_KEY;
            case "stasis_anchor"            -> SUPPORT_PAGE_STASIS_KEY;
            default -> null;
        };
    }

    /**
     * Returns true if the player carries the specific Support Page required
     * to arm the given potion id (see {@link #resolveSupportPageKeyConstForPotion}).
     */
    public boolean hasSupportPageForPotion(Player player, String potionId) {
        String keyConst = resolveSupportPageKeyConstForPotion(potionId);
        if (keyConst == null) return false;
        return hasSupportPage(player, keyConst);
    }

    // ══════════════════════════════════════════════════════════════════════════
    //  MASTER SUPPORT BOOK — carrying it boosts ALL support magic
    // ══════════════════════════════════════════════════════════════════════════

    /**
     * Builds the master Support Book — the "book the pages go in".
     * Carrying this book (in addition to a per-potion Support Page) grants:
     *   +25% to all support/magic damage & healing amounts
     *   +10 seconds to all support buff durations
     */
    public ItemStack buildSupportBook() {
        ItemStack item = new ItemStack(Material.WRITTEN_BOOK);
        BookMeta meta = (BookMeta) item.getItemMeta();
        if (meta != null) {
            meta.setTitle("§5✦ The Support Book");
            meta.setAuthor("§7Ancient Order");
            meta.setGeneration(BookMeta.Generation.ORIGINAL);
            meta.addPage(
                "§5§l─ The Support Book ─\n\n" +
                "§7The tome that binds every\n§5Support Page§7 together.\n\n" +
                "§7Carry this alongside a\nSupport Page to arm its\nBlessing Potion.\n\n" +
                "§d✦ Master Bonus:\n" +
                "§a+25% §7all support magic\n§a+10s §7all buff durations"
            );
            meta.addPage(
                "§5§l─ How Arming Works ─\n\n" +
                "§7Drinking a Blessing Potion\nrequires:\n\n" +
                "§8• §7This §5Support Book§7\n" +
                "§8• §7The matching §5Support Page§7\n" +
                "§8• §7A §dSupport Rune §7present\n\n" +
                "§7Missing any of these →\n§cthe potion shatters§7!"
            );
            meta.getPersistentDataContainer().set(supportBookKey, PersistentDataType.BYTE, (byte) 1);
            item.setItemMeta(meta);
        }
        return item;
    }

    public boolean isSupportBook(ItemStack item) {
        if (item == null || !item.hasItemMeta()) return false;
        return item.getItemMeta().getPersistentDataContainer().has(supportBookKey, PersistentDataType.BYTE);
    }

    public boolean hasSupportBook(Player player) {
        for (ItemStack s : player.getInventory().getContents()) if (isSupportBook(s)) return true;
        if (magicBagManager != null) {
            ItemStack[] bag = magicBagManager.getBag(player.getUniqueId());
            if (bag != null) for (ItemStack s : bag) if (isSupportBook(s)) return true;
        }
        return false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    //  SANDSTORM BOOK — rare 0.2% Tempest Overlord drop
    // ══════════════════════════════════════════════════════════════════════════

    /**
     * Builds the rare Sandstorm Book. Drops ONLY from the Tempest Overlord
     * at a 0.2% chance. Required (alongside Magic Level 99 and a "magic
