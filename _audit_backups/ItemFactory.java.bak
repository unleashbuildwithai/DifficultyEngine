    /**
     * Builds the Gilded Spawner Block — placed inside the Ancient Realm and
     * struck/right-clicked to awaken §6The Gilded Enforcer§r (Pillager +
     * immortal exploding Creeper rider) at the Gilded Sanctum.
     */
    public ItemStack buildGildedSpawner() {
        ItemStack item = new ItemStack(Material.GOLD_BLOCK);
        ItemMeta meta = item.getItemMeta();
        if (meta != null) {
            meta.setDisplayName("§6§lGilded Spawner Block");
            meta.addEnchant(Enchantment.UNBREAKING, 1, true);
            meta.addItemFlags(ItemFlag.HIDE_ENCHANTS);
            meta.setLore(List.of(
                "§8" + "─".repeat(28),
                "§7A block of pure gold, humming with",
                "§7the wrath of a fallen pillager king.",
                "§8" + "─".repeat(28),
                "§6✦ §7Place and strike/click inside §5Ancient Realm",
                "§7  to awaken §6The Gilded Enforcer§7.",
                "§8" + "─".repeat(28),
                "§8[DifficultyEngine — Spawner Block]"
            ));
            meta.getPersistentDataContainer().set(gildedSpawnerKey, PersistentDataType.BYTE, (byte) 1);
            item.setItemMeta(meta);
        }
        return item;
    }

    public boolean isGildedSpawner(ItemStack item) {
        if (item == null || !item.hasItemMeta()) return false;
        return item.getItemMeta().getPersistentDataContainer().has(gildedSpawnerKey, PersistentDataType.BYTE);
    }

    public ItemStack buildSupportStaff() {
        ItemStack staff = new ItemStack(Material.BREEZE_ROD);
        ItemMeta meta = staff.getItemMeta();
