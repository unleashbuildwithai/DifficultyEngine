            meta.setAuthor("§5The Tempest Overlord");
            meta.setGeneration(BookMeta.Generation.ORIGINAL);
            meta.addPage(
                "§6§l─ The Sandstorm Book ─\n\n" +
                "§7Torn from the storm-wracked\nsoul of the §5Tempest Overlord§7.\n\n" +
                "§8Rarity: §c0.2% §8drop chance\n§8(Tempest Overlord ONLY)\n\n" +
                "§7Grants the power to summon\na §6Sandstorm §7with the\n§2Earth Staff§7."
            );
            meta.addPage(
                "§6§l─ Requirements ─\n\n" +
                "§7Right-click §2magic water\n§7(created by the §bWater Staff§7)\n§7with your §2Earth Staff§7 while:\n\n" +
                "§8• §aMagic Level 99\n" +
                "§8• §7Carrying this book\n\n" +
                "§7Missing either → fizzles\nharmlessly (message shown)."
            );
            meta.getPersistentDataContainer().set(sandstormBookKey, PersistentDataType.BYTE, (byte) 1);
            item.setItemMeta(meta);
